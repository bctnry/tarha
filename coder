#!/bin/bash
# Coding Agent REPL Launcher
# Usage: ./coder [options]
#
# Options:
#   --model <name>       Set model (default: glm-5:cloud)
#   --host <url>         Set Ollama host (default: http://localhost:11434)
#   --no-color           Disable colored output
#   -h, --help           Show this help

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUILD_DIR="$SCRIPT_DIR/_build/default/lib"

# Parse arguments
MODEL=${OLLAMA_MODEL:-"glm-5:cloud"}
HOST=${OLLAMA_HOST:-"http://localhost:11434"}
COLOR=1

while [[ $# -gt 0 ]]; do
    case $1 in
        --model)
            MODEL="$2"
            shift 2
            ;;
        --host)
            HOST="$2"
            shift 2
            ;;
        --no-color)
            COLOR=0
            shift
            ;;
        -h|--help)
            echo "Coding Agent REPL - Interactive Coding Assistant"
            echo ""
            echo "Usage: $0 [options]"
            echo ""
            echo "Options:"
            echo "  --model <name>       Set model (default: glm-5:cloud)"
            echo "  --host <url>         Set Ollama host (default: http://localhost:11434)"
            echo "  --no-color           Disable colored output"
            echo "  -h, --help           Show this help"
            echo ""
            echo "Environment Variables:"
            echo "  OLLAMA_MODEL         Override default model"
            echo "  OLLAMA_HOST          Override default host"
            echo ""
            echo "Examples:"
            echo "  $0                           # Start REPL with defaults"
            echo "  $0 --model llama3            # Use different model"
            echo "  $0 --host http://remote:11434"
            echo ""
            exit 0
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Check if build exists
if [ ! -d "$BUILD_DIR" ]; then
    echo "Build not found. Running rebar3 compile..."
    cd "$SCRIPT_DIR"
    rebar3 compile
    if [ $? -ne 0 ]; then
        echo "Compilation failed!"
        exit 1
    fi
fi

# Check Erlang
if ! command -v erl &> /dev/null; then
    echo "Error: Erlang not found. Please install Erlang/OTP."
    exit 1
fi

# Check Ollama connectivity
if command -v curl &> /dev/null; then
    if ! curl -s "$HOST/api/tags" > /dev/null 2>&1; then
        echo "Warning: Cannot connect to Ollama at $HOST"
        echo "Make sure Ollama is running: ollama serve"
    fi
fi

# Set environment
export OLLAMA_MODEL="$MODEL"
export OLLAMA_HOST="$HOST"

# Start REPL with stdin support and crash capture
cd "$SCRIPT_DIR"

# Create crash reports directory
mkdir -p "$SCRIPT_DIR/.coding_agent_reports"
mkdir -p "$SCRIPT_DIR/.tarha/reports"

# Temporary file for crash output
CRASH_LOG=$(mktemp 2>/dev/null || echo "/tmp/coder-crash-$$.log")
trap 'rm -f "$CRASH_LOG" 2>/dev/null' EXIT INT TERM

# Run Erlang and capture output
set +e
erl -noshell -pa "$BUILD_DIR"/*/ebin \
    -eval "application:set_env(coding_agent, model, \"$MODEL\"), application:set_env(coding_agent, ollama_host, \"$HOST\"), application:ensure_all_started(coding_agent), coding_agent_repl:start(), halt()." \
    2>&1 | tee "$CRASH_LOG"
EXIT_CODE=${PIPESTATUS[0]:-$?}
set -e

# Check if crash occurred (look for crash patterns in output)
if [ $EXIT_CODE -ne 0 ] || grep -qE "(Crash|Error|error:|EXIT|undef|case_clause|badarg)" "$CRASH_LOG" 2>/dev/null; then
    # Generate crash ID
    CRASH_ID=$(date +%s | sha256sum 2>/dev/null | head -c 16 || echo "boot-$(date +%s)")
    
    # Determine report location (prefer .tarha/reports for consistency with healer)
    CRASH_FILE="$SCRIPT_DIR/.tarha/reports/crash-${CRASH_ID}.md"
    
    cat > "$CRASH_FILE" << EOF
# Boot-Time Crash Report

**Crash ID:** crash-${CRASH_ID}

**Timestamp:** $(date -u +"%Y-%m-%d %H:%M:%S UTC")

**Module:** boot

**Error Type:** boot_crash

**Error:**

\`\`\`
$(head -100 "$CRASH_LOG")
\`\`\`

## Suggestion

This crash occurred during application startup, before the healer could catch it.

**Common causes:**
1. Merge conflicts not resolved (look for `<<<<<<<` or `=======` in source files)
2. Undefined function (module not compiled or exported)
3. Syntax error in source files

**Fix:** Run \`rebar3 compile\` and fix any errors shown.
EOF
    
    echo ""
    echo "✗ Boot crash saved to: $CRASH_FILE"
    echo "  Run 'cat $CRASH_FILE' to view details"
fi

exit $EXIT_CODE