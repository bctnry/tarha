{application, coding_agent,
 [{description, "Minimal coding agent using Ollama"},
  {vsn, "0.3.0"},
  {registered, []},
  {mod, {coding_agent_app, []}},
  {applications,
   [kernel,
    stdlib,
    hackney,
    jsx,
    crypto,
    cowboy,
    ranch
   ]},
  {env,
   [{ollama_host, "http://localhost:11434"},
    {model, "glm-5:cloud"}
   ]},
     {modules,
      [coding_agent_app,
       coding_agent_sup,
       coding_agent_ollama,
       coding_agent_tools,
       coding_agent,
       coding_agent_session_sup,
       coding_agent_session,
       coding_agent_stream,
       coding_agent_lsp,
       coding_agent_index,
       coding_agent_self,
       coding_agent_healer,
       coding_agent_process_monitor,
       coding_agent_conv_memory,
       coding_agent_skills,
       coding_agent_repl,
       coding_agent_cli,
       coding_agent_http,
       coding_agent_zulip,
       coding_agent_config
      ]}
   ]}.
