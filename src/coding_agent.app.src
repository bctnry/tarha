{application, coding_agent,
 [{description, "Minimal coding agent using Ollama"},
  {vsn, "0.3.0"},
  {registered, []},
  {mod, {coding_agent_app, []}},
  {applications,
   [kernel,
    stdlib,
    hackney,
    jsx,
    crypto
   ]},
  {env,
   [{ollama_host, "http://localhost:11434"}
   ]},
  {modules,
   [coding_agent_app,
    coding_agent_sup,
    coding_agent_config,
    coding_agent_ollama,
    coding_agent_tools,
    coding_agent_tools_build,
    coding_agent_tools_command,
    coding_agent_tools_file,
    coding_agent_tools_git,
    coding_agent_tools_model,
    coding_agent_tools_refactor,
    coding_agent_tools_search,
    coding_agent_tools_self,
    coding_agent_tools_skills,
    coding_agent_tools_undo,
    coding_agent,
    coding_agent_session_sup,
    coding_agent_session,
    coding_agent_session_store,
    coding_agent_stream,
    coding_agent_lsp,
    coding_agent_index,
    coding_agent_self,
    coding_agent_healer,
    coding_agent_process_monitor,
    coding_agent_conv_memory,
    coding_agent_skills,
    coding_agent_repl,
    coding_agent_cli,
    coding_agent_undo,
    coding_agent_request_registry
   ]}
 ]}.
