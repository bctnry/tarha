{erl_opts, [debug_info]}.

{deps, [
    {hackney, "1.20.1"},
    {jsx, "3.1.0"},
    {cowboy, "2.12.0"}
]}.

{shell, [
    {apps, [coding_agent]}
]}.

{pre_hooks, [
    {compile, "mkdir -p _build/default/lib/coding_agent/priv/session_viewer"},
    {compile, "cp -r debug_tool/session_viewer/* _build/default/lib/coding_agent/priv/session_viewer/"}
]}.